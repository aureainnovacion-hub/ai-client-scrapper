# ─────────────────────────────────────────────────────────────────────────────
# Configuración del Scraper — ai-client-scrapper (Aurea Innovación)
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como ".env" y rellena los valores reales.
# El archivo .env NUNCA debe subirse al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Scraper ──────────────────────────────────────────────────────────────────

# Palabra clave de búsqueda en Páginas Amarillas
# Ejemplos: "instalaciones solares", "energias renovables", "climatizacion"
SEARCH_KEYWORD=instalaciones solares

# Número máximo de páginas a paginar por fuente (cada página ~25 empresas)
MAX_PAGES=5

# Ruta de la base de datos SQLite
DATABASE_URL=sqlite:///data/leads.db

# Directorio de logs
LOG_DIR=logs

# Modo headless del navegador (true = sin ventana gráfica, recomendado en servidor)
HEADLESS=true

# ── Enriquecimiento BDNS ─────────────────────────────────────────────────────

# Importe mínimo en € para marcar un lead como prioritario
PRIORITY_MIN_AMOUNT=10000

# Número mínimo de concesiones para marcar un lead como prioritario
PRIORITY_MIN_COUNT=2

# ── SMTP para envío de emails comerciales ────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-password-de-aplicacion

# Modo de prueba: si es "true", los emails se simulan pero NO se envían
DRY_RUN=true
