# ==============================================================
# Configuración de Entorno — ai-client-scrapper
# Aurea Innovación
# ==============================================================
# NO GUARDE SECRETOS EN ESTE ARCHIVO.
# Copie este archivo como ".env" en la raíz del proyecto y
# complete los valores reales antes de ejecutar el proyecto.
# ==============================================================

# ── Aplicación ────────────────────────────────────────────────
APP_NAME=ai-client-scrapper
APP_ENV=development
APP_DEBUG=true

# ── Scraper ───────────────────────────────────────────────────
# Palabra clave de búsqueda en Páginas Amarillas
SEARCH_KEYWORD=instalaciones solares

# Número máximo de páginas a paginar por fuente (~25 empresas/página)
MAX_PAGES=5

# Modo headless del navegador (true = sin ventana gráfica)
HEADLESS=true

# ── Base de datos ─────────────────────────────────────────────
# SQLite (desarrollo por defecto):
DATABASE_URL=sqlite:///data/leads.db

# PostgreSQL (producción, activar perfil postgres en docker-compose):
# DB_CONNECTION=postgresql
# DB_HOST=db
# DB_PORT=5432
# DB_DATABASE=scrapper_prod
# DB_USERNAME=scrapper
# DB_PASSWORD=

# ── Enriquecimiento BDNS ──────────────────────────────────────
# Importe mínimo en € para marcar un lead como prioritario
PRIORITY_MIN_AMOUNT=10000

# Número mínimo de concesiones para marcar un lead como prioritario
PRIORITY_MIN_COUNT=2

# ── SMTP — Envío de emails comerciales ───────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Modo de prueba: si es "true", los emails se simulan pero NO se envían
DRY_RUN=true

# ── Logs ──────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── Docker ────────────────────────────────────────────────────
FRONTEND_PORT=8501
DB_PORT=5432
