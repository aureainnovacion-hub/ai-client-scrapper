# ==============================================================
# .gitignore — ai-client-scrapper
# ==============================================================

# ── Entorno y secretos ────────────────────────────────────────
.env
.env.*
!.env.example
!config/envs/example.env

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Entornos virtuales ────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Datos y logs (persistentes en servidor, no en repo) ───────
data/
logs/
*.db
*.sqlite
*.sqlite3

# ── Playwright ────────────────────────────────────────────────
/ms-playwright/
playwright/.auth/

# ── Node.js (para herramientas de calidad) ────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Docker ────────────────────────────────────────────────────
.docker/

# ── IDEs y editores ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Tests temporales ──────────────────────────────────────────
.env.test
